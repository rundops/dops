{
  "$schema": "https://dops.sh/theme.json",
  "name": "solarized",
  "defs": {
    "base03":    "#002b36",
    "base02":    "#073642",
    "base01":    "#586e75",
    "base0":     "#839496",
    "base1":     "#93a1a1",
    "base2":     "#eee8d5",
    "base3":     "#fdf6e3",
    "yellow":    "#b58900",
    "orange":    "#cb4b16",
    "red":       "#dc322f",
    "redDark":   "#b5200f",
    "magenta":   "#d33682",
    "violet":    "#6c71c4",
    "blue":      "#268bd2",
    "cyan":      "#2aa198",
    "green":     "#859900"
  },
  "theme": {
    "background":        { "dark": "base03",  "light": "base3"   },
    "backgroundPanel":   { "dark": "base02",  "light": "base2"   },
    "backgroundElement": { "dark": "base02",  "light": "base2"   },
    "text":              { "dark": "base0",   "light": "base01"  },
    "textMuted":         { "dark": "base01",  "light": "base1"   },
    "primary":           { "dark": "blue",    "light": "blue"    },
    "border":            { "dark": "base01",  "light": "base1"   },
    "borderActive":      { "dark": "cyan",    "light": "cyan"    },
    "success":           { "dark": "green",   "light": "green"   },
    "warning":           { "dark": "yellow",  "light": "yellow"  },
    "error":             { "dark": "red",     "light": "red"     },
    "risk": {
      "low":      { "dark": "green",   "light": "green"   },
      "medium":   { "dark": "yellow",  "light": "yellow"  },
      "high":     { "dark": "orange",  "light": "orange"  },
      "critical": { "dark": "redDark", "light": "redDark" }
    }
  }
}
